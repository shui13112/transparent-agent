# ============ LLM 配置 ============
# 快速模型（用于子问题拆解等轻量任务）
FAST_LLM_MODEL=deepseek-v4-flash
FAST_LLM_API_KEY=
FAST_LLM_BASE_URL=https://api.deepseek.com/v1

# 智能模型（用于主 agent 推理）
SMART_LLM_MODEL=deepseek-v4-pro
SMART_LLM_API_KEY=
SMART_LLM_BASE_URL=https://api.deepseek.com/v1


# ============ Embedding 向量模型 ============
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============ 搜索检索器 ============
RETRIEVERS=tavily
TAVILY_API_KEY=your_key

# ============ RAG 知识库增强 ============
RAG_MODE=false

